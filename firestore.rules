rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // teams
    match /teams/{teamId} {
      allow read: if request.auth != null;

      // create: 自分がcreatedByかつmemberIdsに含まれること
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.createdBy
                    && request.auth.uid in request.resource.data.memberIds;

      // update:
      //   - メンバーは全フィールド更新可
      //   - 非メンバーはmemberIdsへの自分追加のみ（joinTeam用）
      allow update: if request.auth != null
                    && (request.auth.uid in resource.data.memberIds
                        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
                            && request.auth.uid in request.resource.data.memberIds));

      allow delete: if false;

      // サブコレクション: 認証済みユーザーのみ読み取り、メンバーのみ書き込み
      match /matches/{matchId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                     && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.memberIds;
      }
      match /venues/{venueId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                     && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.memberIds;
      }
      match /players/{playerId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
                     && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.memberIds;
      }
    }
  }
}
